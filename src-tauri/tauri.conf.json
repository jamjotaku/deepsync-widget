{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "deepsync-widget",
  "version": "0.1.0",
  "identifier": "com.deepsync.widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeepSync Widget",
        "width": 320,
        "height": 480,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,   
        "decorations": true    
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://pbs.twimg.com https://*.googleusercontent.com https://docs.google.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://docs.google.com https://*.googleusercontent.com https://*.google.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "http": {}
  }
}
